# Sao chép thành file `.env` trong thư mục `backend/` khi chạy FastAPI trên host (dev).
# Hạ tầng: `docker compose --env-file docker/ragflow/upstream/.env up -d` (không bật profile `app-docker`).

# Postgres ứng dụng — map ra host tại compose (mặc định 127.0.0.1:5433, xem POSTGRES_APP_HOST_PORT).
DATABASE_URL=postgresql+asyncpg://app:app_dev_change_me@127.0.0.1:5433/ragflow_legal

# RAGFlow API — cổng host trong docker/ragflow/upstream/.env (mặc định SVR_HTTP_PORT=19380).
RAGFLOW_BASE_URL=http://127.0.0.1:19380

# Sao chép từ docker/ragflow/upstream/.env (cùng giá trị với stack Docker).
RAGFLOW_API_KEY=ragflow-wIiurdPUeYIEAs3sNjlQgBv0IryC7eKFo5Jfkue7JjE
RAGFLOW_CHAT_ID=d7f7b4fa3adf11f1a2dc39e258fffd6c

# FE dev (next dev) gọi API qua proxy same-origin hoặc trực tiếp tới backend.
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Tạo admin đầu tiên khi bảng users còn trống (chỉ dev; mật khẩu ≥ 8 ký tự cho bcrypt).
BOOTSTRAP_ADMIN_EMAIL=hungnm1486@gmail.com
BOOTSTRAP_ADMIN_PASSWORD=3nhkun2003
